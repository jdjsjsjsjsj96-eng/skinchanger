local config = shared.Nova.skinchanger

if not config or not config.enabled then
    return
end

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer

_G.EquippedData = _G.EquippedData or {}

-- Wait for modules with timeout
local function safeWaitForChild(parent, childName, timeout)
    local child = parent:WaitForChild(childName, timeout or 10)
    if not child then
        warn("[Nova Skinchanger] Failed to find: " .. childName)
        return nil
    end
    return child
end

local Modules = safeWaitForChild(ReplicatedStorage, "Modules")
if not Modules then return end

local CosmeticLibrary = require(safeWaitForChild(Modules, "CosmeticLibrary"))
local ItemLibrary = require(safeWaitForChild(Modules, "ItemLibrary"))
local ReplicatedClass = require(safeWaitForChild(Modules, "ReplicatedClass"))

local PlayerScripts = player:WaitForChild("PlayerScripts", 10)
if not PlayerScripts then return end

local ClientItem = require(PlayerScripts.Modules.ClientReplicatedClasses.ClientFighter.ClientItem)
local ClientViewModel = require(PlayerScripts.Modules.ClientReplicatedClasses.ClientFighter.ClientItem.ClientViewModel)

-- Initialize equipped data from config (supports both old and new format)
for weapon, data in pairs(config) do
    if weapon ~= "enabled" then
        if type(data) == "string" then
            -- Old format: ['Weapon'] = 'Skin'
            _G.EquippedData[weapon] = {Skin = data, Wrap = "None"}
        elseif type(data) == "table" then
            -- New format: ['Weapon'] = {skin = 'Skin', wrap = 'Wrap'}
            _G.EquippedData[weapon] = {
                Skin = data.skin or "Default",
                Wrap = data.wrap or "None"
            }
        end
    end
end

local function getCosmeticData(name, cType)
    local base = CosmeticLibrary.Cosmetics[name]
    if not base then return nil end
    local data = table.clone(base)
    data.Name = name
    data.Type = cType
    if name == "AKEY-47" then
        data.IsMythical = true
        data.BundlePath = "Bundles"
    elseif name:find("Gingerbread") then
        data.BundlePath = "Festive Skin Case"
    end
    return data
end

local oldGetWrap = ClientViewModel.GetWrap
ClientViewModel.GetWrap = function(self)
    local weaponName = self.ClientItem and self.ClientItem.Name
    if weaponName and _G.EquippedData[weaponName] then
        local wrapName = _G.EquippedData[weaponName].Wrap
        if wrapName ~= "None" then return getCosmeticData(wrapName, "Wrap") end
    end
    return oldGetWrap(self)
end

local oldNew = ClientViewModel.new
ClientViewModel.new = function(replicatedData, clientItem)
    local weaponName = clientItem.Name
    if _G.EquippedData[weaponName] and clientItem.ClientFighter.Player == player then
        local dataKey = ReplicatedClass:ToEnum("Data")
        local skinKey = ReplicatedClass:ToEnum("Skin")
        local nameKey = ReplicatedClass:ToEnum("Name")
        replicatedData[dataKey] = replicatedData[dataKey] or {}
        local selectedSkin = _G.EquippedData[weaponName].Skin
        if selectedSkin ~= "Default" then
            replicatedData[dataKey][skinKey] = getCosmeticData(selectedSkin, "Skin")
            replicatedData[dataKey][nameKey] = selectedSkin
        end
    end
    local vm = oldNew(replicatedData, clientItem)
    task.delay(0.1, function() if vm and vm._UpdateWrap then vm:_UpdateWrap() end end)
    return vm
end

-- Auto-equip configured skins and wraps
for weapon, data in pairs(config) do
    if weapon ~= "enabled" then
        local skinName, wrapName
        
        if type(data) == "string" then
            skinName = data
            wrapName = nil
        elseif type(data) == "table" then
            skinName = data.skin
            wrapName = data.wrap
        end
        
        -- Equip skin
        if skinName and skinName ~= "Default" then
            pcall(function() CosmeticLibrary.Equip(weapon, "Skin", skinName) end)
            pcall(function()
                local rem = ReplicatedStorage:FindFirstChild("EquipCosmetic", true) or ReplicatedStorage.Remotes:FindFirstChild("EquipCosmetic")
                if rem then rem:FireServer(weapon, skinName) end
            end)
        end
        
        -- Equip wrap
        if wrapName and wrapName ~= "None" then
            pcall(function() CosmeticLibrary.Equip(weapon, "Wrap", wrapName) end)
            pcall(function()
                local rem = ReplicatedStorage:FindFirstChild("EquipCosmetic", true) or ReplicatedStorage.Remotes:FindFirstChild("EquipCosmetic")
                if rem then rem:FireServer(weapon, wrapName) end
            end)
        end
    end
end

print("[Nova Skinchanger] Loaded successfully with wraps support!")
